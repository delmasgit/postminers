# ==========================================
# Environments & Secrets (CRITICAL)
# ==========================================
.env
.env.local
.env.*
!.env.example

# ==========================================
# Python Cache & Bytecode
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ==========================================
# Virtual Environments
# ==========================================
venv/
env/
.venv/
Pipfile.lock
poetry.lock

# ==========================================
# Django Specific
# ==========================================
*.log
local_settings.py

# Ignore local SQLite databases
db.sqlite3
db.sqlite3-journal

# Ignore media and static files collected during development
media/
staticfiles/
static_root/

# ==========================================
# IDEs & OS Files
# ==========================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ==========================================
# Testing & Coverage
# ==========================================
.coverage
htmlcov/
.pytest_cache/
.tox/